layer-rule {
	match namespace="^noctalia-overview*"
	place-within-backdrop true
}

workspace "code"
workspace "web"
workspace "chat"
workspace "game"
workspace "music"
workspace "misc"

window-rule {
	geometry-corner-radius 12
	clip-to-geometry true
}

window-rule {
	match app-id="^code$"
	match app-id="^dev.zed.Zed$"
	match app-id="^jetbrains-studio$"
	match app-id="^antigravity$"

	open-on-workspace "code"
	open-focused true
}

window-rule {
	match app-id="^(firefox)(.*)$"
	match app-id="^Tor Browser$"

	open-on-workspace "web"
	open-focused true
}

window-rule {
	match app-id="^vesktop$"
	match app-id="^org.telegram.desktop$"
	match app-id="^fluxer_app$"

	open-on-workspace "chat"
	open-focused true
}

window-rule {
	match app-id="^steam$"
	match app-id="^com.heroicgameslauncher.hgl$"
	match app-id="^org.vinegarhq.Sober$"
	match app-id="^PolyMC$"
	match app-id="^(Minecraft)(.*)$"

	open-on-workspace "game"
	open-focused true
}

window-rule {
	match app-id="^spotify$"
	match app-id="^Spotify$"

	open-on-workspace "music"
	open-focused true
}

window-rule {
	match app-id="org.kde.kdenlive" title="Kdenlive"

	match title="^(OBS)(.*)$"

	open-on-workspace "misc"
	open-focused true
}

window-rule {
	match app-id="^(firefox)(.*)$"
	match app-id="^Tor Browser$"
	match app-id="^vesktop$"
	match app-id="^fluxer_app$"
	match app-id="^steam$" title="Steam"
	match app-id="^com.heroicgameslauncher.hgl$"
	match app-id="^spotify$"
	match app-id="^Spotify$"
	match app-id="^org.gnome.Nautilus$" title="Home"
	match app-id="^org.telegram.desktop$"
	match app-id="^code$"
	match app-id="^antigravity$"
	match app-id="^dev.zed.Zed$"
	match app-id="^org.vinegarhq.Sober$" title="Sober"
	match app-id="^ONLYOFFICE$"

	match title="^(OBS)(.*)$"

	default-column-width { proportion 1.0; }
}


window-rule {
	match app-id="com-sun-tools-javac-launcher-SourceLauncher"
	match app-id="^zenity$"
	match app-id="^org.kde.kdenlive$" title="^(Splash Screen)(.*)$"
	match app-id="^org.vinegarhq.Sober$" title="^Servers$"
	match app-id="^org.vinegarhq.Sober$" title="^Buy Robux$"

	match title="^About$"
	match title="^Library$"
	match title="^Pushbullet$"
	match title="^splash$"
	match title="^Android Studio Setup Wizard$"
	match title="^(zoom)(.*)$"
	match title="^(.*)(Properties)$"
	match title="^(Calculator)(.*)$"
	match title="^(Warning)(.*)$"
	match title="^(Splash)(.*)$"
	match title="^(Project Settings)(.*)$"
	match title="^(.*)(KDE Connect Daemon)$"

	open-floating true
}

window-rule {
	match app-id="^vesktop$" title="vesktop"
	match app-id="^zenity$"
	match app-id="^org.gnome.Nautilus$" title="^(Select)(.*)$"

	match title="^splash$"
	match title="^zoom$"
	// match title="^LibreOffice$"
	match title="^(Updater)(.*)$"
	match title="^(Sign in)(.*)$"
	match title="^(Starting Apache)(.*)$"
	match title="^(Warning)(.*)$"
	match title="^(Splash)(.*)$"

	border { off; }
}

window-rule {
	match app-id="^xdg-desktop-portal-gtk$"
	match app-id="^org.gnome.Nautilus$" title="^(Open File)(.*)$"
	match app-id="^org.gnome.Nautilus$" title="^(Select)(.*)$"

	match title="^dialog$"
	match title="^confirm$"
	match title="^(Save As)(.*)$"
	match title="^(Save Image)(.*)$"
	match title="^(Open Folder)(.*)$"
	match title="^(File Upload)(.*)$"
	match title="^(Choose wallpaper)(.*)$"
	match title="^(Choose an image)(.*)$"
	match title="^(blob.)(.*)$"

	default-column-width { proportion 0.7; }
	default-window-height { proportion 0.7; }
}

window-rule {
	match app-id="^(firefox)(.*)$" title="^Picture-in-Picture$"

	default-column-width { fixed 354; }
	default-window-height { fixed 200; }

	default-floating-position x=20 y=20 relative-to="bottom-right"

	open-focused false
	open-floating true

	border { off; }
}

window-rule {
	match app-id="^org.pulseaudio.pavucontrol$"
	match app-id="^pavucontrol-qt$"

	default-column-width { proportion 0.5; }
	default-window-height { proportion 0.7; }

	open-floating true
}

window-rule {
	match app-id="^mpv$"

	default-column-width { fixed 1160; }
	default-window-height { fixed 653; }

	open-floating true
}

window-rule {
	match title="^(Media viewer)(.*)$"

	default-column-width { proportion 0.9; }
	default-window-height { proportion 0.9; }

	open-fullscreen false
	open-floating true

	border { off; }
}

window-rule {
	match title="^(Welcome to)(.*)$"

	default-column-width { proportion 1.0; }
	default-window-height { proportion 1.0; }
}

window-rule {
	match app-id="^(.*)(FileRoller)$"

	default-column-width { fixed 850; }
	default-window-height { fixed 500; }

	open-floating true
}

window-rule {
	match app-id="^spotify$"
	match app-id="^Spotify$"

	open-fullscreen false
	open-maximized false
	open-maximized-to-edges false
}

binds {
	// Terminal
	Mod+Q repeat=false { spawn "foot"; }

	// File managers
	Mod+E repeat=false { spawn "nautilus"; }

	// Control center & settings
	Mod+S repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "controlCenter" "toggle"; }
	Alt+S repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "settings" "toggle"; }

	// Lockscreen
	Mod+L repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "lockScreen" "lock"; }

	// Launcher, clipboard history and emoji
	Mod+Return repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "toggle"; }
	Alt+C repeat=false      { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "clipboard"; }
	Mod+Period repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "emoji"; }

	// Session menu
	Mod+Shift+E repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "sessionMenu" "toggle"; }

	// Notifications history and notifications clear
	Alt+Escape repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "notifications" "clear"; }

	// Wallpaper selector
	Alt+W repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "wallpaper" "toggle"; }

	// Plugins
	Alt+A repeat=false       { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "plugin:translator" "toggle" "" ""; }
	Alt+T repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "plugin:todo" "togglePanel";}
	Alt+Z repeat=false       { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "plugin:notes-scratchpad" "togglePanel"; }
	Alt+I repeat=false       { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "plugin:ip-monitor" "toggle"; }
	Alt+M repeat=false       { spawn-sh "qs -c noctalia-shell ipc call plugin:slot-machine spin;qs -c noctalia-shell ipc call plugin:slot-machine reset"; }
	Alt+Shift+M repeat=false { spawn-sh "qs -c noctalia-shell ipc call plugin:slot-machine toggle"; }
	Alt+O repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "plugin:shell-profiles" "toggleProfiles"; }
	Alt+P repeat=false { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "plugin:port-monitor" "toggle"; }


	// System controls
	XF86AudioRaiseVolume allow-when-locked=true cooldown-ms=50  { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "increase"; }
	XF86AudioLowerVolume allow-when-locked=true cooldown-ms=50  { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "decrease"; }
	XF86AudioMute allow-when-locked=true repeat=false            { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "muteOutput"; }
	XF86AudioMicMute allow-when-locked=true repeat=false         { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "muteInput"; }
	XF86MonBrightnessUp allow-when-locked=true cooldown-ms=50   {	spawn "qs" "-c" "noctalia-shell" "ipc" "call" "brightness" "increase"; }
	XF86MonBrightnessDown allow-when-locked=true cooldown-ms=50 { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "brightness" "decrease"; }

	// Close window
	Mod+C repeat=false { close-window; }

	Mod+W repeat=false { toggle-overview; }

	Mod+Left repeat=false       { focus-column-left; }
	Mod+Shift+Down repeat=false { focus-window-down; }
	Mod+Shift+Up repeat=false   { focus-window-up; }
	Mod+Right repeat=false      { focus-column-right; }

	Mod+Ctrl+Left repeat=false  { move-column-left; }
	Mod+Ctrl+Down repeat=false  { move-window-down; }
	Mod+Ctrl+Up repeat=false    { move-window-up; }
	Mod+Ctrl+Right repeat=false { move-column-right; }

	Mod+Down repeat=false { focus-workspace-down; }
	Mod+Up repeat=false   { focus-workspace-up; }

	Mod+Alt+Down repeat=false { move-column-to-workspace-down; }
	Mod+Alt+Up repeat=false   { move-column-to-workspace-up; }

	Mod+Shift+WheelScrollDown { focus-workspace-down; }
	Mod+Shift+WheelScrollUp   { focus-workspace-up; }
	Mod+Alt+WheelScrollDown   { move-column-to-workspace-down; }
	Mod+Alt+WheelScrollUp     { move-column-to-workspace-up; }

	Mod+WheelScrollDown      { focus-column-right; }
	Mod+WheelScrollUp        { focus-column-left; }
	Mod+Ctrl+WheelScrollDown { move-column-right; }
	Mod+Ctrl+WheelScrollUp   { move-column-left; }

	Mod+1 repeat=false { focus-workspace 1; }
	Mod+2 repeat=false { focus-workspace 2; }
	Mod+3 repeat=false { focus-workspace 3; }
	Mod+4 repeat=false { focus-workspace 4; }
	Mod+5 repeat=false { focus-workspace 5; }
	Mod+6 repeat=false { focus-workspace 6; }
	Mod+7 repeat=false { focus-workspace 7; }
	Mod+8 repeat=false { focus-workspace 8; }
	Mod+9 repeat=false { focus-workspace 9; }
	Mod+0 repeat=false { focus-workspace 10; }

	// Mod+1 cooldown-ms=500 { spawn-sh "niri msg action toggle-overview && sleep 0.15 && niri msg action focus-workspace 1 && sleep 0.15 && niri msg action toggle-overview"; }
	// Mod+2 cooldown-ms=500 { spawn-sh "niri msg action toggle-overview && sleep 0.15 && niri msg action focus-workspace 2 && sleep 0.15 && niri msg action toggle-overview"; }
	// Mod+3 cooldown-ms=500 { spawn-sh "niri msg action toggle-overview && sleep 0.15 && niri msg action focus-workspace 3 && sleep 0.15 && niri msg action toggle-overview"; }
	// Mod+4 cooldown-ms=500 { spawn-sh "niri msg action toggle-overview && sleep 0.15 && niri msg action focus-workspace 4 && sleep 0.15 && niri msg action toggle-overview"; }
	// Mod+5 cooldown-ms=500 { spawn-sh "niri msg action toggle-overview && sleep 0.15 && niri msg action focus-workspace 5 && sleep 0.15 && niri msg action toggle-overview"; }
	// Mod+6 cooldown-ms=500 { spawn-sh "niri msg action toggle-overview && sleep 0.15 && niri msg action focus-workspace 6 && sleep 0.15 && niri msg action toggle-overview"; }
	// Mod+7 cooldown-ms=500 { spawn-sh "niri msg action toggle-overview && sleep 0.15 && niri msg action focus-workspace 7 && sleep 0.15 && niri msg action toggle-overview"; }
	// Mod+8 cooldown-ms=500 { spawn-sh "niri msg action toggle-overview && sleep 0.15 && niri msg action focus-workspace 8 && sleep 0.15 && niri msg action toggle-overview"; }
	// Mod+9 cooldown-ms=500 { spawn-sh "niri msg action toggle-overview && sleep 0.15 && niri msg action focus-workspace 9 && sleep 0.15 && niri msg action toggle-overview"; }
	// Mod+0 cooldown-ms=500 { spawn-sh "niri msg action toggle-overview && sleep 0.15 && niri msg action focus-workspace 10 && sleep 0.15 && niri msg action toggle-overview"; }

	Mod+Ctrl+1 repeat=false { move-column-to-workspace 1; }
	Mod+Ctrl+2 repeat=false { move-column-to-workspace 2; }
	Mod+Ctrl+3 repeat=false { move-column-to-workspace 3; }
	Mod+Ctrl+4 repeat=false { move-column-to-workspace 4; }
	Mod+Ctrl+5 repeat=false { move-column-to-workspace 5; }
	Mod+Ctrl+6 repeat=false { move-column-to-workspace 6; }
	Mod+Ctrl+7 repeat=false { move-column-to-workspace 7; }
	Mod+Ctrl+8 repeat=false { move-column-to-workspace 8; }
	Mod+Ctrl+9 repeat=false { move-column-to-workspace 9; }
	Mod+Ctrl+0 repeat=false { move-column-to-workspace 10; }

	Mod+BracketLeft repeat=false        { consume-or-expel-window-left; }
	Mod+BracketRight repeat=false       { consume-or-expel-window-right; }
	Mod+Shift+BracketLeft repeat=false  { consume-window-into-column; }
	Mod+Shift+BracketRight repeat=false { expel-window-from-column; }

	Mod+R repeat=false       { switch-preset-column-width; }
	Mod+Ctrl+R repeat=false  { switch-preset-window-height; }
	Mod+Shift+R repeat=false { reset-window-height; }

	Mod+X repeat=false { maximize-column; }
	Mod+F repeat=false { fullscreen-window; }
	Alt+F repeat=false { maximize-window-to-edges; }

	Mod+V repeat=false       { center-column; }
	Mod+Shift+V repeat=false { center-visible-columns; }

	Mod+Minus       { set-column-width "-10%"; }
	Mod+Equal       { set-column-width "+10%"; }
	Mod+Shift+Minus { set-window-height "-10%"; }
	Mod+Shift+Equal { set-window-height "+10%"; }

	Mod+A repeat=false { toggle-window-floating; }
	Mod+D repeat=false { switch-focus-between-floating-and-tiling; }

	Mod+J { toggle-column-tabbed-display; }

	Mod+Shift+S repeat=false { screenshot show-pointer=false; }
	Print repeat=false       { screenshot-screen show-pointer=false; }
	Mod+Shift+W repeat=false { screenshot-window write-to-disk=false show-pointer=false; }

	Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
}

debug {
	// disable-cursor-plane
	render-drm-device "/dev/dri/renderD128"
	ignore-drm-device "/dev/dri/renderD129"
	// emulate-zero-presentation-time
	// disable-resize-throttling
	// disable-transactions
	// skip-cursor-only-updates-during-vrr
	// honor-xdg-activation-with-invalid-serial
}
